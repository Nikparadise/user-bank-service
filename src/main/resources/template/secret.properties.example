# Шаблон файла с секретами/учётными данными. Скопируйте его в src/main/resources/secret.properties
# и подставьте свои значения (выполнять из каталога src/main/resources):
#   Linux/Mac:   cp template/secret.properties.example secret.properties
#   PowerShell:  Copy-Item template/secret.properties.example secret.properties
#
# Сам secret.properties в git не попадает (см. .gitignore).

# Секрет подписи JWT — Base64-ключ не короче 256 бит (32 байта) для HS256.
# Сгенерировать: openssl rand -base64 32
jwt.secret=ЗАМЕНИТЕ_НА_СВОЙ_BASE64_КЛЮЧ

# Подключение к БД (значения ниже соответствуют docker-compose.yml для локального запуска).
db.url=jdbc:postgresql://localhost:5432/userbank
db.username=userbank
db.password=userbank
